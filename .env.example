# ─── Groq Configuration ─────────────────────────────────────────────────────
# Get your key from https://console.groq.com/keys
GROQ_API_KEY=gsk_your-groq-api-key-here
GROQ_MODEL=llama-3.3-70b-versatile

# ─── OpenAI Configuration (Deprecated) ──────────────────────────────────────
# OPENAI_API_KEY=sk-your-openai-api-key-here
# OPENAI_MODEL=gpt-4o-mini

# ─── Tesseract OCR ────────────────────────────────────────────────────────────
# Windows path example:
TESSERACT_PATH=C:\Program Files\Tesseract-OCR\tesseract.exe
# Linux/macOS (usually auto-detected):
# TESSERACT_PATH=/usr/bin/tesseract

# ─── Poppler (required for PDF → image on Windows) ────────────────────────────
# Download from: https://github.com/oschwartz10612/poppler-windows/releases
# Extract the archive, then set this to the "bin" folder inside it.
POPPLER_PATH=C:\poppler\Library\bin

# ─── Embedding Model ──────────────────────────────────────────────────────────
# SentenceTransformers model (downloaded automatically on first run)
EMBEDDING_MODEL=all-MiniLM-L6-v2

# ─── Application Settings ─────────────────────────────────────────────────────
APP_HOST=0.0.0.0
APP_PORT=8000
DEBUG=false

# ─── Storage ──────────────────────────────────────────────────────────────────
UPLOAD_DIR=data/uploads
FAISS_INDEX_DIR=data/faiss_index
LOG_LEVEL=INFO

# ─── Email Configuration (Password Reset) ─────────────────────────────────────
# Choose provider: smtp, sendgrid, or resend
EMAIL_PROVIDER=smtp
FROM_EMAIL=your email address
FROM_NAME=DocuMind AI
FRONTEND_URL=http://localhost:3000

# SMTP Settings (Gmail example)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your email address
SMTP_PASSWORD=your smtp password

# SendGrid Settings (alternative)
# SENDGRID_API_KEY=SG.your-sendgrid-api-key

# Resend Settings (alternative - recommended for development)
# RESEND_API_KEY=re_your-resend-api-key
